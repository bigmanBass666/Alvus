# ─────────────────────────────────────────────
# Alvus Configuration
# ─────────────────────────────────────────────

# Your API keys, comma-separated (REQUIRED)
# Get free NVIDIA NIM keys at: https://build.nvidia.com
API_KEYS=nvapi-xxxxxxxxxxxx,nvapi-yyyyyyyyyyyy,nvapi-zzzzzzzzzzzz

# Port for the proxy to listen on
PORT=3000

# Upstream API base URL
# Default: NVIDIA NIM (LLMs and chat models)
TARGET_BASE_URL=https://integrate.api.nvidia.com/v1

# Upstream base URL for image/genai requests (/genai/ paths)
# Default: NVIDIA NIM visual models host
GENAI_BASE_URL=https://ai.api.nvidia.com

# How many seconds to cool a key after a 429 response
# 60s works well for most free-tier providers
COOLDOWN_SEC=60